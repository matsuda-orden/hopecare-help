# Notion インテグレーションのシークレットキー
# Notion → 設定 → インテグレーション → シークレットキーをコピー
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GCP Cloud Storage バケット名（デプロイ先）
# 例: my-bucket-name（gs:// は不要）
GCS_BUCKET=your-bucket-name

# Notion DB ID（省略時はデフォルト値を使用）
# DB_GUIDE=e357eaa3-2b46-480c-bad5-87b38cc0f2aa
# DB_QA=9989558f-d86a-46b3-88f7-eef62b7114e4
# DB_TROUBLE=621131f7-5b8a-4c3b-9aa0-42d332179166
